# Copia este archivo a backend/.env y rellena los valores reales.
# Generado a partir de un grep real sobre el código — cada variable de acá
# es leída por algún os.getenv() en el proyecto, no es una lista aspiracional.

# --- Obligatorias: sin estas, el backend no arranca ---
TELEGRAM_BOT_TOKEN=123456789:AA...tu-token-de-BotFather
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key

# Recomendada: bypassa RLS al subir archivos a Storage y consultar el catálogo.
# Si falta, el código cae de vuelta a SUPABASE_KEY (puede fallar en buckets privados).
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Voz por Telegram (Whisper) ---
GROQ_API_KEY=tu-groq-key

# --- Sistema RAG (opcional: si faltan, /rag/search y /rag/sync fallan
# silencioso y el bot sigue funcionando igual, solo sin correcciones aprendidas) ---
# Usa UNA de las dos, según EMBEDDING_PROVIDER en app/ai/rag/config.py:
OPENAI_API_KEY=sk-...
VOYAGE_API_KEY=pa-...

# --- Observabilidad (opcional: si falta, app/ai/tracing.py cae a no-op,
# el bot funciona igual pero sin trazas en smith.langchain.com) ---
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=plataforma-racks
